---
import FilterSwatch from "@/components/site/FilterSwatch.astro";
import LocalTime from "@/components/site/LocalTime.astro";
import { getSessionStatusLabel, getSessionStatusTone, isSessionOnline } from "@/lib/session-status";
import type { StoredSession } from "@/lib/site-types";
import { formatDuration } from "@nina/format";

interface Props {
  session: StoredSession;
}

const { session } = Astro.props as Props;

const statusLabel = getSessionStatusLabel(session);
const statusTone = getSessionStatusTone(session);
const online = isSessionOnline(session);
const statusDotClass = statusTone === "online"
  ? "bg-emerald-400 shadow-[0_0_14px_rgba(52,211,153,0.5)]"
  : statusTone === "offline"
    ? "bg-rose-400 shadow-[0_0_14px_rgba(251,113,133,0.4)]"
    : "bg-white/30";
const FILTER_SORT_ORDER = ["L", "R", "G", "B", "Ha", "OIII", "SII", "Unfiltered"];
const targetName = (() => {
  if (session.currentState?.currentTarget?.name) {
    return session.currentState.currentTarget.name;
  }

  if (!session.targetNames.length) {
    return "No target";
  }

  if (session.targetNames.length === 1) {
    return session.targetNames[0];
  }

  if (session.targetNames.length === 2) {
    return session.targetNames.join(" / ");
  }

  return `${session.targetNames[0]} +${session.targetNames.length - 1} more`;
})();
const filterNames = [...session.filterNames].sort((left, right) => {
  const leftIndex = FILTER_SORT_ORDER.indexOf(left);
  const rightIndex = FILTER_SORT_ORDER.indexOf(right);

  if (leftIndex !== -1 || rightIndex !== -1) {
    if (leftIndex === -1) {
      return 1;
    }
    if (rightIndex === -1) {
      return -1;
    }
    if (leftIndex !== rightIndex) {
      return leftIndex - rightIndex;
    }
  }

  return left.localeCompare(right);
});
const visibleFilterNames = filterNames.slice(0, 5);
const remainingFilterCount = Math.max(0, filterNames.length - visibleFilterNames.length);
const thumbnailTitle = targetName === "No target" ? session.displayName : targetName;
---

<article class="border-t border-line-soft py-5 first:border-t-0">
  <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_10rem] md:items-start xl:grid-cols-[minmax(0,1fr)_12rem]">
    <a
      href={`/sessions/${encodeURIComponent(session.sessionKey)}`}
      class="group grid min-w-0 gap-4 md:grid-cols-[5.5rem_minmax(0,1fr)] md:items-start xl:grid-cols-[6rem_minmax(0,1fr)]"
    >
      <div class="hidden md:block">
        <div class="font-mono text-[0.62rem] uppercase tracking-[0.22em] text-ink-soft">
          <LocalTime value={session.startedAt} format="month-day" />
        </div>
        <div class="mt-1 text-[0.9rem] text-ink-muted">
          <LocalTime value={session.startedAt} format="time" />
        </div>
      </div>

      <div class="min-w-0">
        <div class="min-w-0">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="truncate text-[1.08rem] font-medium tracking-[-0.03em] text-ink-strong transition-colors group-hover:text-white">
                {session.displayName}
              </div>
              <div class="mt-1 truncate text-[0.98rem] text-ink-muted">{targetName}</div>
              <div class="mt-2 md:hidden text-[0.82rem] text-ink-soft">
                <LocalTime value={session.startedAt} format="date-time-short" />
              </div>
            </div>
            <div
              class:list={[
                "inline-flex shrink-0 items-center gap-2 rounded-full border px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-[0.18em]",
                online
                  ? "border-white/20 text-live-soft"
                  : "border-white/10 text-ink-soft",
              ]}
            >
              <span class:list={["h-2 w-2 rounded-full", statusDotClass]} />
              {statusLabel}
            </div>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.82rem] text-ink-muted">
          {session.profileName ? <span>{session.profileName}</span> : null}
          <span>{session.exposureCount} subs</span>
          <span>{formatDuration(session.totalExposureSeconds)}</span>
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 text-[0.78rem] text-ink-soft">
          {visibleFilterNames.length ? visibleFilterNames.map((filterName) => (
            <FilterSwatch
              filterName={filterName === "Unfiltered" ? null : filterName}
              class="text-[0.78rem] text-ink-soft"
              labelClass="font-mono uppercase tracking-[0.16em]"
            />
          )) : <span>—</span>}
          {remainingFilterCount ? (
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-ink-soft">
              +{remainingFilterCount}
            </span>
          ) : null}
        </div>
      </div>
    </a>

    <div class="hidden md:block">
      {session.heroThumbnailUrl ? (
        <button
          type="button"
          data-lightbox-src={session.heroThumbnailUrl}
          data-lightbox-label="Session preview"
          data-lightbox-title={thumbnailTitle}
          data-lightbox-time={session.startedAt}
          data-lightbox-alt={thumbnailTitle}
          class="block w-full cursor-zoom-in overflow-hidden rounded-[14px] border border-line-soft bg-black/30 text-left shadow-[0_16px_40px_rgba(0,0,0,0.22)] transition-transform hover:scale-[1.01]"
          aria-label="Expand session preview"
        >
          <img
            src={session.heroThumbnailUrl}
            alt={thumbnailTitle}
            class="aspect-[4/3] w-full object-cover"
          />
        </button>
      ) : (
        <div class="flex aspect-[4/3] items-center justify-center rounded-[14px] border border-dashed border-line-soft bg-black/18 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-ink-soft">
          No preview
        </div>
      )}
    </div>
  </div>
</article>
