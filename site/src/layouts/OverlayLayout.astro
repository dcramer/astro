---
import "@/styles/overlay.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Live overlay for the current imaging session.",
  noindex = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <slot />
  </body>
</html>
