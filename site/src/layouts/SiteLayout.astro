---
import ImageLightbox from "@/components/site/ImageLightbox.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  imagePath?: string | null;
  imageAlt?: string | null;
  ogType?: "website" | "article";
  publishedTime?: string | null;
  modifiedTime?: string | null;
  oembed?: boolean;
  noindex?: boolean;
}

const {
  title,
  description = "Astrophotography session status and archive.",
  imagePath = null,
  imageAlt = null,
  ogType = "website",
  publishedTime = null,
  modifiedTime = null,
  oembed = true,
  noindex = false,
} =
  Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.url).toString();
const absoluteImageUrl = imagePath ? new URL(imagePath, Astro.url).toString() : null;
const oembedUrl = !noindex && oembed
  ? new URL(`/oembed?url=${encodeURIComponent(canonicalUrl)}&format=json`, Astro.url).toString()
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:site_name" content="astro.cra.mr" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:alt" content={imageAlt ?? title} />}
    {absoluteImageUrl && <meta name="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta name="twitter:image:alt" content={imageAlt ?? title} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {oembedUrl && <link rel="alternate" type="application/json+oembed" href={oembedUrl} title={title} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <slot />
    <ImageLightbox />
    <script is:inline>
      (() => {
        const formatters = {
          time: new Intl.DateTimeFormat(undefined, {
            hour: "numeric",
            minute: "2-digit",
          }),
          "date-time": new Intl.DateTimeFormat(undefined, {
            dateStyle: "medium",
            timeStyle: "short",
          }),
          "date-time-short": new Intl.DateTimeFormat(undefined, {
            month: "short",
            day: "numeric",
            hour: "numeric",
            minute: "2-digit",
          }),
          "month-day": new Intl.DateTimeFormat(undefined, {
            month: "short",
            day: "numeric",
          }),
        };

        const updateTimes = () => {
          document.querySelectorAll("[data-local-time]").forEach((node) => {
            const element = node;
            const format = element.getAttribute("data-local-time");
            const dateTime = element.getAttribute("datetime");
            if (!format || !dateTime) {
              return;
            }

            const formatter = formatters[format];
            const parsed = new Date(dateTime);
            if (!formatter || Number.isNaN(parsed.getTime())) {
              return;
            }

            element.textContent = formatter.format(parsed);
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", updateTimes, { once: true });
        } else {
          updateTimes();
        }
      })();
    </script>
  </body>
</html>
