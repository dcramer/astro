---
import { env } from "cloudflare:workers";

import {
  computeExposureProgress,
  formatCameraStatus,
  getRemainingSeconds,
} from "@/components/overlay/utils/camera";
import { formatMountDisplay } from "@/components/overlay/utils/mount";
import { findSequenceItemByPath } from "@/components/overlay/utils/sequence/navigation";
import {
  formatSequenceProgressSuffix,
  formatSequenceStatus,
  normalizeSequenceBreadcrumbEntry,
} from "@/components/overlay/utils/sequence/format";
import {
  formatAmbientTemperature,
  formatHumidity,
  formatSkyQuality,
} from "@/components/overlay/utils/weather";
import FilterSwatch from "@/components/site/FilterSwatch.astro";
import LocalTime from "@/components/site/LocalTime.astro";
import PublicHeader from "@/components/site/PublicHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getPreferredTargetName, getStoredSessionTargetName } from "@/lib/current-target";
import { getExposureById, getLiveApiResponse, getSessionExposures } from "@/lib/db";
import { buildHomePageMetadata } from "@/lib/page-metadata";
import { getSessionStatusLabel, getSessionStatusTone, isSessionOnline } from "@/lib/session-status";
import { formatDuration, formatNumber } from "@nina/format";

const live = await getLiveApiResponse(env);
const sessionExposures = live.session ? await getSessionExposures(env, live.session.sessionKey, 500) : [];
const heroExposure = live.session?.heroExposureId ? await getExposureById(env, live.session.heroExposureId) : null;
const currentState = live.session?.currentState;
const latestExposure = live.images[0] ?? null;
const now = Date.now();
const buildAssetUrl = (assetKey: string | null) =>
  assetKey
    ? `/api/assets/${assetKey.split("/").map(encodeURIComponent).join("/")}`
    : null;
const toArchivedDisplayImage = (
  exposure: (typeof sessionExposures)[number] | null,
) => exposure
  ? {
      exposureDurationSeconds: exposure.durationSeconds,
      filterName: exposure.filterName ?? "—",
      startTime: exposure.startedAt,
      detectedStars: exposure.detectedStars,
      hfr: exposure.hfr,
      rmsText: exposure.guidingRmsArcSec !== null ? `${exposure.guidingRmsArcSec.toFixed(2)}"` : "—",
      targetName: exposure.targetName,
      thumbnailUrl: buildAssetUrl(exposure.thumbnailKey),
    }
  : null;
const currentTargetSnapshot = currentState?.currentTarget ?? null;
const currentTargetBase = getPreferredTargetName({
  currentTarget: currentTargetSnapshot,
  latestExposureTargetName: latestExposure?.targetName ?? null,
  targetNames: live.session?.targetNames ?? [],
  primaryTargetName: live.session?.primaryTargetName ?? null,
}) ?? "No target";
const currentTarget = live.liveMode === "active-pending" &&
  (
    currentTargetBase === "No target" ||
    currentTargetBase === "Current pointing" ||
    currentTargetSnapshot?.source === "mount"
  )
  ? "Startup Sequence"
  : currentTargetBase;
const isOnline = isSessionOnline(live.session);
const camera = isOnline ? live.advanced?.camera ?? null : null;
const connectionOptions = {
  connectionOffline: live.stale || !live.hasConnected,
  hasConnected: live.hasConnected,
};
const remainingSeconds = getRemainingSeconds(camera, now);
const cameraProgress = camera
  ? computeExposureProgress(
      camera,
      now,
      latestExposure?.exposureDurationSeconds ?? camera.lastExposureDurationSeconds ?? null,
      remainingSeconds,
      remainingSeconds,
    )
  : null;
const cameraStatus = camera
  ? formatCameraStatus(camera, now, cameraProgress)
  : isOnline
    ? "—"
    : "<Offline>";
const mountStatus = formatMountDisplay(live.mount, connectionOptions);
const skyQuality = formatSkyQuality(live.weather, connectionOptions);
const ambientTemperature = formatAmbientTemperature(live.weather, connectionOptions);
const humidity = formatHumidity(live.weather, connectionOptions);

const sequence = isOnline ? live.advanced?.sequence ?? null : null;
const runningSequenceItem = findSequenceItemByPath(sequence?.items, sequence?.breadcrumb ?? null);
const sequenceProgressSuffix = formatSequenceProgressSuffix(runningSequenceItem, now);
let sequenceStatus = sequence
  ? formatSequenceStatus(sequence)
  : isOnline
    ? "—"
    : "<Offline>";

if (sequenceProgressSuffix) {
  sequenceStatus = `${sequenceStatus}${sequenceProgressSuffix}`;
}

const sequenceBreadcrumb = sequence?.breadcrumb?.length
  ? sequence.breadcrumb
      .filter((entry): entry is string => Boolean(entry))
      .filter((entry, index) => !(index === 0 && entry.toLowerCase().includes("container")))
      .map((entry) => normalizeSequenceBreadcrumbEntry(entry))
      .filter((entry): entry is string => Boolean(entry))
  : [];
const sequenceTrail = sequenceBreadcrumb.length ? sequenceBreadcrumb.join(" / ") : null;
const latestDisplayExposure = toArchivedDisplayImage(sessionExposures[0] ?? null);
const heroDisplayExposure = toArchivedDisplayImage(heroExposure);
const showBestArchivedPreview = live.liveMode !== "active-pending" && !isOnline;
const archivedDisplayExposure = showBestArchivedPreview
  ? heroDisplayExposure ?? latestDisplayExposure
  : latestDisplayExposure;
const primaryDisplayImage = live.liveMode === "active-pending"
  ? live.images.find((image) => Boolean(image.thumbnailUrl)) ?? null
  : archivedDisplayExposure;
const primaryDisplayLabel = live.liveMode === "active-pending"
  ? "Current run"
  : showBestArchivedPreview
    ? "Best sub"
    : "Latest sub";
const primaryDisplayTitle = live.liveMode === "active-pending"
  ? currentTarget
  : archivedDisplayExposure?.targetName ?? currentTarget;
const cameraProgressPercent = cameraProgress ? Math.max(0, Math.min(100, Math.round(cameraProgress.percent * 100))) : null;
const primaryDisplayHfr = archivedDisplayExposure?.hfr !== null && archivedDisplayExposure?.hfr !== undefined
  ? formatNumber(archivedDisplayExposure.hfr, 2)
  : "—";
const primaryDisplayStars = archivedDisplayExposure?.detectedStars !== null && archivedDisplayExposure?.detectedStars !== undefined
  ? String(archivedDisplayExposure.detectedStars)
  : "—";
const primaryDisplayGuideRms = archivedDisplayExposure?.rmsText ?? "—";
const sessionTargetTitle = getStoredSessionTargetName(live.session) ?? currentTarget;
const liveStatusTone = getSessionStatusTone(live.session);
const liveStatusLabel = getSessionStatusLabel(live.session);
const liveStatusDetail = !live.session
  ? "Waiting for the first valid sub."
  : live.liveMode === "active-pending"
    ? isOnline
      ? "Sequence is running; first valid sub has not completed yet."
      : "Current session is not reporting new data; first valid sub has not completed yet."
    : live.liveMode === "active-imaging"
      ? isOnline
        ? "Current session is reporting new data."
        : "Current session is not reporting new data."
      : "Showing the most recent archived session.";
const liveStatusDotClass = liveStatusTone === "online"
  ? "bg-white shadow-[0_0_16px_rgba(255,255,255,0.18)]"
  : liveStatusTone === "offline"
    ? "bg-white/30"
    : "bg-white/18";
const FILTER_SORT_ORDER = ["L", "R", "G", "B", "Ha", "OIII", "SII", "Unfiltered"];
const filterLabels = new Set<string>();
const previewPanelClass = "rounded-[18px] border border-white/10 bg-black px-4 py-4";
const statPanelClass = "rounded-[18px] border border-white/10 bg-black px-4 py-4";
const metricCardClass = "rounded-[16px] border border-white/10 bg-black px-4 py-3";
const badgeClass = "inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/80 px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-white/70";
const sessionSummaryCardClass = "rounded-[18px] border border-line-soft bg-[image:var(--background-image-panel-surface)] px-6 py-6 shadow-[0_24px_80px_rgba(0,0,0,0.24)] sm:px-7 sm:py-7";
const showSessionDetailsLayout = Boolean(live.session && !isOnline);
const filterGroups = sessionExposures.reduce<Record<string, { count: number; total: number }>>((accumulator, exposure) => {
  const key = exposure.filterName?.trim() || "Unfiltered";
  const existing = accumulator[key] ?? { count: 0, total: 0 };
  existing.count += 1;
  existing.total += exposure.durationSeconds;
  accumulator[key] = existing;
  return accumulator;
}, {});

for (const exposure of sessionExposures) {
  filterLabels.add(exposure.filterName?.trim() || "Unfiltered");
}

if (!filterLabels.size && archivedDisplayExposure?.filterName) {
  filterLabels.add(archivedDisplayExposure.filterName.trim());
}

function compareFilterLabels(left: string, right: string): number {
  const leftIndex = FILTER_SORT_ORDER.indexOf(left);
  const rightIndex = FILTER_SORT_ORDER.indexOf(right);

  if (leftIndex !== -1 || rightIndex !== -1) {
    if (leftIndex === -1) {
      return 1;
    }
    if (rightIndex === -1) {
      return -1;
    }
    if (leftIndex !== rightIndex) {
      return leftIndex - rightIndex;
    }
  }

  return left.localeCompare(right);
}

const filterBreakdown = Array.from(filterLabels).sort(compareFilterLabels);
const orderedFilterGroups = Object.entries(filterGroups).sort(([left], [right]) => compareFilterLabels(left, right));
const primaryFilterLabel = archivedDisplayExposure?.filterName?.trim() || "—";
const pageMetadata = buildHomePageMetadata(live);
---

<SiteLayout
  title={pageMetadata.title}
  description={pageMetadata.description}
  imagePath={pageMetadata.imagePath}
  imageAlt={pageMetadata.imageAlt}
  ogType={pageMetadata.ogType}
  publishedTime={pageMetadata.publishedTime}
  modifiedTime={pageMetadata.modifiedTime}
>
  <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 sm:px-8 lg:px-12">
    <PublicHeader />

    <section class="pt-2">
      <div class="grid gap-7 lg:grid-cols-[minmax(18rem,21rem)_minmax(0,1fr)] lg:items-start">
          <div class="space-y-4 lg:sticky lg:top-8">
            {primaryDisplayImage?.thumbnailUrl ? (
              <button
                type="button"
                data-lightbox-src={primaryDisplayImage.thumbnailUrl}
                data-lightbox-label={primaryDisplayLabel}
                data-lightbox-title={primaryDisplayTitle}
                data-lightbox-time={live.liveMode === "active-pending" ? live.session?.startedAt ?? "" : primaryDisplayImage.startTime}
                data-lightbox-filter={live.liveMode === "active-pending" ? "" : primaryDisplayImage.filterName ?? ""}
                data-lightbox-duration={live.liveMode === "active-pending" ? "" : formatDuration(primaryDisplayImage.exposureDurationSeconds)}
                data-lightbox-hfr={live.liveMode === "active-pending" ? "" : primaryDisplayHfr}
                data-lightbox-stars={live.liveMode === "active-pending" ? "" : primaryDisplayStars}
                data-lightbox-rms={live.liveMode === "active-pending" ? "" : primaryDisplayGuideRms}
                data-lightbox-alt={primaryDisplayTitle}
                class="block cursor-zoom-in overflow-hidden rounded-[18px] border border-white/10 bg-black text-left shadow-[0_20px_60px_rgba(0,0,0,0.42)] transition-transform hover:scale-[1.002]"
                aria-label={live.liveMode === "active-pending"
                  ? "Expand current run preview"
                  : primaryDisplayLabel === "Best sub"
                    ? "Expand best exposure"
                    : "Expand latest exposure"}
              >
                <img
                  src={primaryDisplayImage.thumbnailUrl}
                  alt={primaryDisplayTitle}
                  class="aspect-[4/3] w-full object-cover"
                />
              </button>
            ) : (
              <div class="flex aspect-[4/3] flex-col items-center justify-center rounded-[20px] border border-dashed border-line-soft bg-black/30 px-6 text-center">
                <div class="font-mono text-[0.68rem] uppercase tracking-[0.2em] text-ink-soft">
                  {primaryDisplayLabel}
                </div>
                <div class="mt-3 text-[1rem] font-medium tracking-[-0.02em] text-ink-strong">
                  {live.liveMode === "active-pending" ? currentTarget : "Waiting for first real sub"}
                </div>
                <div class="mt-2 max-w-[16rem] text-[0.84rem] leading-6 text-ink-muted">
                  {live.liveMode === "active-pending"
                    ? (sequenceStatus !== "<Offline>" ? sequenceStatus : "Sequence is waiting for the first valid sub.")
                    : "Waiting for the first valid sub."}
                </div>
              </div>
            )}

            <section class={previewPanelClass}>
              <div class="flex items-center justify-between gap-3">
                <div class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-ink-soft">
                  {primaryDisplayLabel}
                </div>
                {archivedDisplayExposure && live.liveMode !== "active-pending" ? (
                  <span class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-ink-muted">
                    {primaryFilterLabel}
                  </span>
                ) : null}
              </div>

              {live.liveMode === "active-pending" ? (
                <div class="mt-4 grid gap-4">
                  <div>
                    <div class="text-[1.08rem] font-medium tracking-[-0.02em] text-ink-strong">
                      {currentTarget}
                    </div>
                    <div class="mt-1 text-[0.9rem] text-ink-muted">
                      {sequenceStatus !== "<Offline>" ? sequenceStatus : "First valid sub has not completed yet."}
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-x-4 gap-y-3">
                    <div class="col-span-2 border-t border-line-soft pt-2.5">
                      <div class="font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">State</div>
                      <div class="mt-1 text-[0.94rem] text-ink-strong">
                        {isOnline
                          ? "Awaiting first valid sub"
                          : "Current session offline before first valid sub"}
                      </div>
                    </div>
                  </div>
                </div>
              ) : archivedDisplayExposure ? (
                <div class="mt-4 grid gap-4">
                  <div>
                    <div class="text-[1.08rem] font-medium tracking-[-0.02em] text-ink-strong">
                      {archivedDisplayExposure.targetName ?? currentTarget}
                    </div>
                    <div class="mt-1 text-[0.86rem] text-ink-muted">
                      <LocalTime value={archivedDisplayExposure.startTime} format="date-time-short" />
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-x-4 gap-y-3">
                    <div class="border-t border-white/10 pt-2.5">
                      <div class="font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">Duration</div>
                      <div class="mt-1 text-[0.94rem] text-ink-strong">
                        {formatDuration(archivedDisplayExposure.exposureDurationSeconds)}
                      </div>
                    </div>
                    <div class="border-t border-white/10 pt-2.5">
                      <div class="font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">HFR</div>
                      <div class="mt-1 text-[0.94rem] text-ink-strong">{primaryDisplayHfr}</div>
                    </div>
                    <div class="border-t border-white/10 pt-2.5">
                      <div class="font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">Stars</div>
                      <div class="mt-1 text-[0.94rem] text-ink-strong">{primaryDisplayStars}</div>
                    </div>
                    <div class="border-t border-white/10 pt-2.5">
                      <div class="font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">Guide RMS</div>
                      <div class="mt-1 text-[0.94rem] text-ink-strong">{primaryDisplayGuideRms}</div>
                    </div>
                  </div>
                </div>
              ) : (
                <div class="mt-4 text-[0.92rem] text-ink-muted">No completed subs have been archived yet.</div>
              )}
            </section>
          </div>

          <div class="flex flex-col gap-8">
            {showSessionDetailsLayout && live.session ? (
              <>
                <article class={sessionSummaryCardClass}>
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div
                      class:list={[
                        "inline-flex items-center gap-2 rounded-full border px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-[0.16em]",
                        liveStatusTone === "online" ? "border-white/20 text-live-soft" : "border-white/10 text-ink-soft",
                      ]}
                    >
                      <span class:list={["h-2 w-2 rounded-full", liveStatusDotClass]} />
                      {liveStatusLabel}
                    </div>

                    <div class="flex flex-wrap items-center gap-2">
                      <div class={badgeClass}>{live.session.displayName}</div>
                      {live.session.profileName ? (
                        <div class={badgeClass}>{live.session.profileName}</div>
                      ) : null}
                    </div>
                  </div>

                  <h1 class="mt-5 text-[2rem] font-medium tracking-[-0.045em] text-ink-strong sm:text-[2.4rem]">
                    {sessionTargetTitle}
                  </h1>

                  <p class="mt-3 text-[0.96rem] leading-7 text-ink-muted">
                    Started <LocalTime value={live.session.startedAt} format="date-time" />
                    {live.session.endedAt ? (
                      <> · Ended <LocalTime value={live.session.endedAt} format="date-time" /></>
                    ) : live.session.activeSession ? (
                      <> · Last seen <LocalTime value={live.session.lastSeenAt} format="date-time" /></>
                    ) : null}
                  </p>

                  <div class="mt-4 max-w-2xl text-[0.92rem] text-ink-muted">
                    {liveStatusDetail}
                  </div>

                  <div class="mt-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                    <div class="rounded-[16px] border border-line-soft bg-white/[0.015] px-4 py-3">
                      <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Subs</div>
                      <div class="mt-2 text-[1.05rem] font-medium text-ink-strong">{live.session.exposureCount}</div>
                    </div>
                    <div class="rounded-[16px] border border-line-soft bg-white/[0.015] px-4 py-3">
                      <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Integration</div>
                      <div class="mt-2 text-[1.05rem] font-medium text-ink-strong">
                        {formatDuration(live.session.totalExposureSeconds)}
                      </div>
                    </div>
                    <div class="rounded-[16px] border border-line-soft bg-white/[0.015] px-4 py-3">
                      <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Profile</div>
                      <div class="mt-2 text-[1.05rem] font-medium text-ink-strong">{live.session.profileName ?? "—"}</div>
                    </div>
                    <div class="rounded-[16px] border border-line-soft bg-white/[0.015] px-4 py-3">
                      <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Session</div>
                      <a
                        href={`/sessions/${encodeURIComponent(live.session.sessionKey)}`}
                        class="mt-2 inline-flex text-[1.05rem] font-medium text-ink-strong transition-colors hover:text-white"
                      >
                        Open archive
                      </a>
                    </div>
                  </div>
                </article>

                <section class={sessionSummaryCardClass}>
                  <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Filter mix</div>
                  <div class="mt-5 grid gap-3">
                    {orderedFilterGroups.length ? orderedFilterGroups.map(([filter, group]) => (
                      <div class="flex items-baseline justify-between gap-3 border-t border-line-soft pt-3 first:border-t-0 first:pt-0">
                        <FilterSwatch
                          filterName={filter === "Unfiltered" ? null : filter}
                          class="text-[0.98rem] text-ink-strong"
                        />
                        <span class="text-sm text-ink-muted">
                          {group.count} · {formatDuration(group.total)}
                        </span>
                      </div>
                    )) : (
                      <div class="text-sm text-ink-soft">No exposures were archived for this session yet.</div>
                    )}
                  </div>
                </section>
              </>
            ) : (
              <>
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <div class={badgeClass}>
                      <span class:list={["h-2 w-2 rounded-full", liveStatusDotClass]} />
                      {liveStatusLabel}
                    </div>

                    {live.session ? (
                      <div class={badgeClass}>
                        {live.session.displayName}
                      </div>
                    ) : null}

                    {live.session?.profileName ? (
                      <div class={badgeClass}>
                        {live.session.profileName}
                      </div>
                    ) : null}
                  </div>

                  <div class="mt-6">
                    <div class="min-w-0">
                      <div class="font-mono text-[0.58rem] uppercase tracking-[0.26em] text-ink-soft">
                        Target
                      </div>
                      <h1
                        class="mt-3 max-w-full overflow-hidden text-ellipsis whitespace-nowrap text-[clamp(2.4rem,5vw,4.8rem)] font-medium leading-[0.95] tracking-[-0.06em] text-ink-strong"
                        title={currentTarget}
                      >
                        {currentTarget}
                      </h1>

                      <div class="mt-4 max-w-xl text-[0.92rem] text-ink-muted">
                        {liveStatusDetail}
                      </div>

                      {sequenceTrail ? (
                        <div class="mt-5 border-l border-white/14 pl-4 font-mono text-[0.72rem] uppercase tracking-[0.15em] text-ink-muted">
                          {sequenceTrail}
                        </div>
                      ) : null}
                    </div>
                </div>

                  {cameraProgressPercent !== null ? (
                    <div class="mt-6">
                      <div class="flex items-center justify-between gap-3 font-mono text-[0.56rem] uppercase tracking-[0.22em] text-ink-soft">
                        <span>Exposure progress</span>
                        <span>{cameraProgressPercent}%</span>
                      </div>
                      <div class="mt-2 h-2.5 overflow-hidden rounded-full bg-white/8">
                        <div
                          class="h-full rounded-full bg-[linear-gradient(90deg,rgba(255,255,255,0.9),rgba(255,255,255,0.45))]"
                          style={`width:${cameraProgressPercent}%`}
                        />
                      </div>
                    </div>
                  ) : null}
                </div>

                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-6">
                  <section class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Camera</div>
                    <div class="mt-2 text-[1rem] font-medium text-ink-strong">{cameraStatus}</div>
                  </section>
                  <section class:list={[metricCardClass, "xl:col-span-2"]}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Mount</div>
                    <div class="mt-2 text-[1rem] font-medium leading-6 text-ink-strong">{mountStatus}</div>
                  </section>
                  <section class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Sky quality</div>
                    <div class="mt-2 text-[1rem] font-medium text-ink-strong">{skyQuality}</div>
                  </section>
                  <section class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Ambient</div>
                    <div class="mt-2 text-[1rem] font-medium text-ink-strong">{ambientTemperature}</div>
                  </section>
                  <section class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Humidity</div>
                    <div class="mt-2 text-[1rem] font-medium text-ink-strong">{humidity}</div>
                  </section>
                  <section class:list={[statPanelClass, "sm:col-span-2 xl:col-span-6"]}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.24em] text-ink-soft">Sequencer</div>
                    <div class="mt-2 text-[1rem] font-medium text-ink-strong">{sequenceStatus}</div>
                    {sequenceTrail ? (
                      <div class="mt-3 border-t border-white/10 pt-3 font-mono text-[0.72rem] uppercase tracking-[0.14em] text-ink-muted">
                        {sequenceTrail}
                      </div>
                    ) : null}
                  </section>
                </div>

                <div class="grid gap-4 sm:grid-cols-3">
                  <div class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Total subs</div>
                    <div class="mt-1 text-[1.15rem] font-medium text-ink-strong">{live.session?.exposureCount ?? 0}</div>
                  </div>
                  <div class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Integration</div>
                    <div class="mt-1 text-[1.15rem] font-medium text-ink-strong">
                      {live.session ? formatDuration(live.session.totalExposureSeconds) : "—"}
                    </div>
                  </div>
                  <div class={metricCardClass}>
                    <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Filters</div>
                    <div class="mt-2 flex flex-wrap items-center gap-2 text-[0.92rem] text-ink-strong">
                      {filterBreakdown.length ? filterBreakdown.map((filter) => (
                        <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.03] px-2.5 py-1 font-mono text-[0.72rem] uppercase tracking-[0.12em] text-ink-muted">
                          {filter}
                        </span>
                      )) : (
                        <span class="text-[0.96rem] text-ink-muted">—</span>
                      )}
                    </div>
                  </div>
                </div>
              </>
            )}
          </div>
      </div>
    </section>
  </div>
</SiteLayout>
