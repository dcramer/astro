---
import { env } from "cloudflare:workers";

import PublicHeader from "@/components/site/PublicHeader.astro";
import SessionArchiveRow from "@/components/site/SessionArchiveRow.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getRecentSessions } from "@/lib/db";
import { buildArchivePageMetadata } from "@/lib/page-metadata";
import type { StoredSession } from "@/lib/site-types";
import { formatDuration } from "@nina/format";

const sessions = await getRecentSessions(env, 60);
const totalIntegrationSeconds = sessions.reduce(
  (total, session) => total + session.totalExposureSeconds,
  0,
);
const distinctTargetCount = (() => {
  const targetNames = new Set<string>();

  for (const session of sessions) {
    if (session.targetNames.length) {
      for (const targetName of session.targetNames) {
        targetNames.add(targetName);
      }
    } else if (session.primaryTargetName) {
      targetNames.add(session.primaryTargetName);
    }
  }

  return targetNames.size;
})();

const monthFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
});

function getMonthKey(value: string): string {
  return value.slice(0, 7);
}

function getMonthLabel(value: string): string {
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? value : monthFormatter.format(parsed);
}

const groupedSessions = sessions.reduce<Array<{ key: string; label: string; sessions: StoredSession[] }>>(
  (groups, session) => {
    const key = getMonthKey(session.startedAt);
    const existing = groups[groups.length - 1];

    if (existing && existing.key === key) {
      existing.sessions.push(session);
      return groups;
    }

    groups.push({
      key,
      label: getMonthLabel(session.startedAt),
      sessions: [session],
    });
    return groups;
  },
  [],
);
const pageMetadata = buildArchivePageMetadata(sessions);
---

<SiteLayout
  title={pageMetadata.title}
  description={pageMetadata.description}
  imagePath={pageMetadata.imagePath}
  imageAlt={pageMetadata.imageAlt}
  ogType={pageMetadata.ogType}
  publishedTime={pageMetadata.publishedTime}
  modifiedTime={pageMetadata.modifiedTime}
>
  <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 sm:px-8 lg:px-12">
    <PublicHeader />

    <section class="mb-10 grid gap-6 pt-2 lg:grid-cols-[minmax(0,1.2fr)_minmax(19rem,0.8fr)] lg:items-end">
      <div>
        <h1 class="text-[2.35rem] font-medium tracking-[-0.06em] text-ink-strong sm:text-[3rem]">
          Session History
        </h1>
      </div>

      <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
        <div class="rounded-[16px] border border-line-soft bg-black/16 px-4 py-4">
          <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Sessions</div>
          <div class="mt-2 text-[1.2rem] font-medium text-ink-strong">{sessions.length}</div>
        </div>
        <div class="rounded-[16px] border border-line-soft bg-black/16 px-4 py-4">
          <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Integration</div>
          <div class="mt-2 text-[1.2rem] font-medium text-ink-strong">{formatDuration(totalIntegrationSeconds)}</div>
        </div>
        <div class="rounded-[16px] border border-line-soft bg-black/16 px-4 py-4">
          <div class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ink-soft">Targets</div>
          <div class="mt-2 text-[1.2rem] font-medium text-ink-strong">{distinctTargetCount}</div>
        </div>
      </div>
    </section>

    {sessions.length ? (
      <div class="space-y-10">
        {groupedSessions.map((group) => (
          <section>
            <div class="mb-4 flex items-center justify-between gap-4 border-b border-line-soft pb-3">
              <h2 class="text-[1.2rem] font-medium tracking-[-0.03em] text-ink-strong">{group.label}</h2>
              <div class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-ink-soft">
                {group.sessions.length} {group.sessions.length === 1 ? "session" : "sessions"}
              </div>
            </div>

            <div class="border-y border-line-soft">
              {group.sessions.map((session) => <SessionArchiveRow session={session} />)}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="border-y border-line-soft py-8 text-sm text-ink-soft">No sessions have been synced yet.</div>
    )}
  </div>
</SiteLayout>
