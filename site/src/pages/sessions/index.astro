---
import { env } from "cloudflare:workers";

import LocalTime from "@/components/site/LocalTime.astro";
import PublicHeader from "@/components/site/PublicHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getRecentSessions } from "@/lib/db";
import { formatDuration } from "@nina/format";

const sessions = await getRecentSessions(env, 60);
---

<SiteLayout title="Session Archive" description="Archived astrophotography sessions.">
  <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 sm:px-8 lg:px-12">
    <PublicHeader />

    <section class="mb-7">
      <h1 class="text-[2rem] font-medium tracking-[-0.045em] text-ink-strong sm:text-[2.4rem]">Archive</h1>
    </section>

    {sessions.length ? (
      <div class="border-y border-line-soft">
        {sessions.map((session) => (
          <a
            class="grid gap-4 border-t border-line-soft py-5 first:border-t-0 md:grid-cols-[minmax(0,1.4fr)_minmax(0,0.9fr)_minmax(0,0.7fr)_auto] md:items-center"
            href={`/sessions/${encodeURIComponent(session.sessionKey)}`}
          >
            <div class="min-w-0">
              <strong class="block text-[1rem] font-medium text-ink-strong">{session.displayName}</strong>
              <div class="mt-1 text-sm text-ink-muted">
                <LocalTime value={session.startedAt} format="date-time-short" />
              </div>
            </div>
            <div class="min-w-0">
              <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Target</div>
              <div class="mt-2 text-[0.98rem] text-ink-muted">{session.currentState?.currentTarget?.name ?? "—"}</div>
            </div>
            <div>
              <div class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-soft">Integration</div>
              <div class="mt-2 text-[0.98rem] text-ink-muted">{formatDuration(session.totalExposureSeconds)}</div>
            </div>
            <div>
              <div
                class:list={[
                  "inline-flex items-center rounded-full border px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-[0.16em]",
                  session.stale ? "border-white/10 text-ink-soft" : "border-white/20 text-ink-muted",
                ]}
              >
                {session.activeSession && !session.stale ? "Live" : session.endedAt ? "Completed" : "Stale"}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="border-y border-line-soft py-8 text-sm text-ink-soft">No sessions have been synced yet.</div>
    )}
  </div>
</SiteLayout>
