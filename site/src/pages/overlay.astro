---
import OverlayLayout from "@/layouts/OverlayLayout.astro";
import OverlayDisplay from "@/components/overlay/OverlayDisplay";

const initialNow = Date.now();
---

<OverlayLayout title="Astro Overlay" description="Live overlay for the current imaging session.">
  <OverlayDisplay client:load initialNow={initialNow} pollMs={5000} />
</OverlayLayout>
