{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".next/**",
    "build/**",
    "node_modules/**",
    "out/**",
    "packages/astro-catalog/dist/**",
    "next-env.d.ts"
  ],
  "plugins": [
    "eslint",
    "import",
    "jsx-a11y",
    "nextjs",
    "oxc",
    "react",
    "typescript",
    "unicorn"
  ],
  "settings": {
    "next": {
      "rootDir": "."
    },
    "react": {
      "version": "19.1.0"
    }
  }
}
